---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'IT professional in Phoenix, Arizona, building toward cybersecurity and DevOps.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme = stored || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <Header />
    <main id="main"><slot /></main>
    <Footer />
    <script is:inline>
      (function () {
        try {
          var endpoint = 'https://srv1522777.tail72f980.ts.net:8448/pixel';
          var visitorKey = 'marco_site_visitor_id';
          var ownerKey = 'marco_site_owner';
          var params = new URLSearchParams(window.location.search);
          if (params.get('owner') === 'marco') {
            localStorage.setItem(ownerKey, '1');
          }
          var visitorId = localStorage.getItem(visitorKey);
          if (!visitorId) {
            visitorId = 'v_' + Math.random().toString(36).slice(2) + '_' + Date.now().toString(36);
            localStorage.setItem(visitorKey, visitorId);
          }
          var sessionKey = 'marco_site_session_id';
          var visitCountKey = 'marco_site_visit_count';
          var sessionId = sessionStorage.getItem(sessionKey);
          if (!sessionId) {
            sessionId = 's_' + Math.random().toString(36).slice(2) + '_' + Date.now().toString(36);
            sessionStorage.setItem(sessionKey, sessionId);
          }
          var visitCount = Number(localStorage.getItem(visitCountKey) || '0') + 1;
          localStorage.setItem(visitCountKey, String(visitCount));
          var connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection || {};
          var navigationEntry = performance && performance.getEntriesByType
            ? performance.getEntriesByType('navigation')[0]
            : null;
          var pageLoadMs = navigationEntry && navigationEntry.loadEventEnd
            ? Math.round(navigationEntry.loadEventEnd).toString()
            : '';
          var landingKey = 'marco_site_landing_path';
          var previousPathKey = 'marco_site_previous_path';
          var landingPath = sessionStorage.getItem(landingKey);
          if (!landingPath) {
            landingPath = window.location.pathname;
            sessionStorage.setItem(landingKey, landingPath);
          }
          var previousPath = localStorage.getItem(previousPathKey) || '';
          localStorage.setItem(previousPathKey, window.location.pathname);
          var startedAt = Date.now();
          var maxScrollPct = 0;
          function currentScrollPct() {
            var doc = document.documentElement;
            var body = document.body;
            var scrollTop = window.pageYOffset || doc.scrollTop || body.scrollTop || 0;
            var scrollHeight = Math.max(body.scrollHeight || 0, doc.scrollHeight || 0, body.offsetHeight || 0, doc.offsetHeight || 0);
            var viewportHeight = window.innerHeight || doc.clientHeight || 0;
            var denom = Math.max(1, scrollHeight - viewportHeight);
            return Math.max(0, Math.min(100, Math.round((scrollTop / denom) * 100)));
          }
          function refreshScroll() {
            maxScrollPct = Math.max(maxScrollPct, currentScrollPct());
          }
          window.addEventListener('scroll', refreshScroll, { passive: true });
          var urlParams = new URLSearchParams(window.location.search);
          function sendVisit(eventType) {
            refreshScroll();
            var query = new URLSearchParams({
              visitorId: visitorId,
              session_id: sessionId,
              visit_count: String(visitCount),
              event_type: eventType,
              owner: localStorage.getItem(ownerKey) === '1' ? '1' : '0',
              url: window.location.href,
              path: window.location.pathname,
              landing_path: landingPath,
              previous_path: previousPath,
              search: window.location.search,
              hash: window.location.hash,
              referrer: document.referrer || '',
              title: document.title,
              language: navigator.language || '',
              screen: window.screen ? String(window.screen.width) + 'x' + String(window.screen.height) : '',
              viewport: String(window.innerWidth) + 'x' + String(window.innerHeight),
              page_height: String(Math.max(document.body.scrollHeight || 0, document.documentElement.scrollHeight || 0)),
              orientation: window.screen && window.screen.orientation ? String(window.screen.orientation.type || '') : '',
              timezone_offset: String(new Date().getTimezoneOffset()),
              color_depth: window.screen ? String(window.screen.colorDepth || '') : '',
              pixel_ratio: String(window.devicePixelRatio || ''),
              touch_points: String(navigator.maxTouchPoints || 0),
              platform: navigator.platform || '',
              vendor: navigator.vendor || '',
              cookies_enabled: String(navigator.cookieEnabled),
              do_not_track: navigator.doNotTrack || window.doNotTrack || '',
              online: String(navigator.onLine),
              connection_type: connection.effectiveType || connection.type || '',
              connection_downlink: connection.downlink ? String(connection.downlink) : '',
              connection_rtt: connection.rtt ? String(connection.rtt) : '',
              save_data: connection.saveData ? '1' : '0',
              device_memory: navigator.deviceMemory ? String(navigator.deviceMemory) : '',
              hardware_concurrency: navigator.hardwareConcurrency ? String(navigator.hardwareConcurrency) : '',
              nav_type: navigationEntry ? String(navigationEntry.type || '') : '',
              visibility_state: document.visibilityState || '',
              page_load_ms: pageLoadMs,
              scroll_depth_pct: String(maxScrollPct),
              time_on_page_ms: String(Math.max(0, Date.now() - startedAt)),
              history_length: String(window.history ? window.history.length : ''),
              utm_source: urlParams.get('utm_source') || '',
              utm_medium: urlParams.get('utm_medium') || '',
              utm_campaign: urlParams.get('utm_campaign') || '',
              timezone: Intl.DateTimeFormat().resolvedOptions().timeZone || '',
              cache: Date.now().toString(36)
            });
            var pixel = new Image(1, 1);
            pixel.referrerPolicy = 'origin-when-cross-origin';
            pixel.src = endpoint + '?' + query.toString();
          }
          sendVisit('page_view');
          var sentExit = false;
          function sendExit() {
            if (sentExit) return;
            sentExit = true;
            sendVisit('page_exit');
          }
          document.addEventListener('visibilitychange', function () {
            if (document.visibilityState === 'hidden') sendExit();
          });
          window.addEventListener('pagehide', sendExit);
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      (function () {
        var items = Array.prototype.slice.call(document.querySelectorAll('.reveal'));
        if (!items.length) return;

        var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion || !('IntersectionObserver' in window)) {
          items.forEach(function (item) { item.classList.add('in'); });
          return;
        }

        items.forEach(function (item) { item.classList.add('js-reveal'); });
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              observer.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.12 });

        items.forEach(function (item) { observer.observe(item); });
      })();
    </script>
  </body>
</html>
